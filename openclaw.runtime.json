{
  "logging": {
    "level": "info",
    "consoleLevel": "info",
    "consoleStyle": "pretty",
    "redactSensitive": "tools"
  },
  "models": {
    "providers": {
      "amazon-bedrock": {
        "baseUrl": "https://bedrock-runtime.us-east-1.amazonaws.com",
        "auth": "aws-sdk",
        "api": "bedrock-converse-stream",
        "models": [
          {
            "id": "us.anthropic.claude-opus-4-6-v1",
            "name": "Claude Opus 4.6 (Bedrock)",
            "reasoning": true,
            "input": [
              "text",
              "image"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    },
    "bedrockDiscovery": {
      "enabled": false,
      "region": "us-east-1",
      "providerFilter": [
        "anthropic"
      ],
      "refreshInterval": 3600,
      "defaultContextWindow": 200000,
      "defaultMaxTokens": 8192
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "amazon-bedrock/us.anthropic.claude-opus-4-6-v1"
      },
      "workspace": "/home/ec2-user/clawd-bot",
      "repoRoot": "/home/ec2-user/clawd-bot",
      "userTimezone": "America/New_York"
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "Clawd",
        "identity": {
          "name": "Clawd",
          "theme": "concise Obsidian workflow assistant",
          "emoji": "\ud83e\udd9e"
        },
        "tools": {
          "alsoAllow": [
            "clawd-obsidian",
            "exec"
          ]
        }
      }
    ]
  },
  "tools": {
    "profile": "minimal",
    "alsoAllow": [
      "clawd-obsidian",
      "exec"
    ],
    "media": {
      "audio": {
        "enabled": true,
        "maxBytes": 20971520,
        "models": [
          {
            "provider": "openai",
            "model": "gpt-4o-mini-transcribe"
          },
          {
            "type": "cli",
            "command": "/home/ec2-user/clawd-bot/.venv/bin/python",
            "args": [
              "-m",
              "clawd_ops.openclaw_audio_cli",
              "{{MediaPath}}"
            ],
            "timeoutSeconds": 1800
          }
        ],
        "echoTranscript": true,
        "echoFormat": "Heard:\n{transcript}"
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "scope": "per-sender",
    "resetTriggers": [
      "/new",
      "/reset",
      "/hardstop"
    ],
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 240
    },
    "typingIntervalSeconds": 5
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "8545446581:AAE7ST2aGjAp1nng7_p0IRN5Ag9uTiGwqu4",
      "allowFrom": [
        "8383879897"
      ],
      "groupPolicy": "disabled",
      "streaming": "partial"
    }
  },
  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "none"
    }
  },
  "plugins": {
    "enabled": true,
    "allow": [
      "clawd-obsidian",
      "telegram"
    ],
    "slots": {
      "memory": "none"
    },
    "entries": {
      "clawd-obsidian": {
        "enabled": true,
        "config": {
          "bridgeCwd": "/home/ec2-user/clawd-bot",
          "pythonExec": "/home/ec2-user/clawd-bot/.venv/bin/python",
          "timeoutMs": 60000
        }
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.8",
    "lastTouchedAt": "2026-04-04T09:04:38.624Z"
  },
  "messages": {
    "tts": {
      "auto": "tagged",
      "provider": "openai",
      "openai": {
        "model": "gpt-4o-mini-tts",
        "voice": "alloy"
      },
      "edge": {
        "enabled": true,
        "voice": "en-US-GuyNeural",
        "lang": "en-US"
      },
      "modelOverrides": {
        "enabled": true
      }
    }
  }
}