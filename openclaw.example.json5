{
  agents: {
    defaults: {
      workspace: ".",
      model: {
        primary: "amazon-bedrock/<OPENCLAW_BEDROCK_MODEL_ID>",
      },
      tools: {
        allow: ["clawd-obsidian"],
      },
    },
  },
  models: {
    providers: {
      "amazon-bedrock": {
        baseUrl: "https://bedrock-runtime.<AWS_REGION>.amazonaws.com",
        api: "bedrock-converse-stream",
        auth: "aws-sdk",
        models: [
          {
            id: "<OPENCLAW_BEDROCK_MODEL_ID>",
            name: "Claude via Amazon Bedrock",
            reasoning: true,
            input: ["text", "image"],
            cost: { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 },
            contextWindow: 200000,
            maxTokens: 8192,
          },
        ],
      },
    },
    bedrockDiscovery: {
      enabled: true,
      region: "<AWS_REGION>",
      providerFilter: ["anthropic"],
    },
  },
  channels: {
    telegram: {
      enabled: true,
      botToken: "<TELEGRAM_BOT_TOKEN>",
      dmPolicy: "allowlist",
      allowFrom: ["<TELEGRAM_USER_ID>"],
    },
  },
  plugins: {
    enabled: true,
    entries: {
      "clawd-obsidian": {
        enabled: true,
        config: {
          pythonExec: ".venv/bin/python",
          bridgeCwd: ".",
          timeoutMs: 60000,
        },
      },
    },
  },
}
